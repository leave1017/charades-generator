{
  "redirects": [
    { "source": "/blog/:article.html", "destination": "/blog/:article/", "permanent": true },
    { "source": "/blog/:article",      "destination": "/blog/:article/", "permanent": false },
    { "source": "/:page.html",         "destination": "/:page/",         "permanent": true },
    { "source": "/:page",              "destination": "/:page/",         "permanent": false }
  ],
  "rewrites": [
    { "source": "/blog/:article/", "destination": "/blog/:article.html" },
    { "source": "/:page/",         "destination": "/:page.html" }
  ]
}
